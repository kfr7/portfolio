  <script is:inline>
    const arena = document.getElementById('arena');
    const bug = document.getElementById('bug');
    const start = document.getElementById('start');
    const timeEl = document.getElementById('time');
    const scoreEl = document.getElementById('score');
    const bestEl = document.getElementById('best');

    let timer = 25;
    let score = 0;
    let gameInterval;
    let moveInterval;
    const best = Number(localStorage.getItem('kian-bug-best') || 0);
    bestEl.textContent = String(best);

    const moveBug = () => {
      const x = Math.random() * (arena.clientWidth - 52);
      const y = Math.random() * (arena.clientHeight - 52);
      bug.style.left = `${x}px`;
      bug.style.top = `${y}px`;
    };

    bug.addEventListener('click', () => {
      if (timer <= 0) return;
      score += 1;
      scoreEl.textContent = String(score);
      moveBug();
    });

    start.addEventListener('click', () => {
      clearInterval(gameInterval);
      clearInterval(moveInterval);
      timer = 25;
      score = 0;
      timeEl.textContent = '25';
      scoreEl.textContent = '0';
      moveBug();
      moveInterval = setInterval(moveBug, 950);
      gameInterval = setInterval(() => {
        timer -= 1;
        timeEl.textContent = String(timer);
        if (timer <= 0) {
          clearInterval(gameInterval);
          clearInterval(moveInterval);
          const currentBest = Number(localStorage.getItem('kian-bug-best') || 0);
          if (score > currentBest) {
            localStorage.setItem('kian-bug-best', String(score));
            bestEl.textContent = String(score);
          }
        }
      }, 1000);
    });
  </script>
