---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  'Python', 'JavaScript', 'Vue', 'React', 'Node.js', 'Express.js', 'SQL', 'AWS', 'GCP',
  'Docker', 'Cypress', 'OpenAI', 'Tailwind CSS', 'MongoDB', 'PostgreSQL', 'CI/CD'
];

const experience = [
  {
    role: 'Full-Stack Engineer II → III',
    company: 'Brandboom',
    period: 'Jan 2024 — Present',
    logo: 'https://logo.clearbit.com/brandboom.com',
    bullets: [
      'Promoted to Engineer III in 15 months in a fast-moving startup environment.',
      'Built AI-powered workflows and integrations that improved reliability and measurable platform outcomes.',
      'Led testing and frontend modernization efforts while mentoring teammates.'
    ]
  },
  {
    role: 'Software Engineer Intern, Backend · Full-Stack Intern',
    company: 'Course Hero',
    period: 'Jun 2022 — Sep 2023',
    logo: 'https://logo.clearbit.com/coursehero.com',
    bullets: [
      'Contributed to event-driven AWS systems for faster, more scalable document processing.',
      'Built APIs and documentation that improved user experience and internal handoff.'
    ]
  },
  {
    role: 'Tutor for Intermediate Programmers (C++)',
    company: 'UCI ICS Department',
    period: 'Jan 2022 — May 2022',
    logo: 'https://logo.clearbit.com/uci.edu',
    bullets: ['Facilitated labs and coached students through core data structures and implementation concepts.']
  },
  {
    role: 'Founder / President, Programming Club (Python)',
    company: 'Tesoro High School',
    period: 'Sep 2019 — Jun 2020',
    logo: '',
    bullets: ['Taught CS fundamentals and supported peers through guided project work.']
  }
];
---

<BaseLayout title="Kian Fabian Ranjbar | Portfolio" description="Portfolio of Kian Fabian Ranjbar, full-stack engineer.">
  <section class="glass">
    <p class="inline-flex rounded-full border border-sky-400/40 bg-sky-400/10 px-3 py-1 text-xs text-sky-200">Open to full-stack + AI engineering roles</p>
    <h1 class="mt-4 text-4xl font-extrabold tracking-tight md:text-6xl">Kian Fabian Ranjbar</h1>
    <p class="mt-4 max-w-3xl leading-relaxed text-slate-300">
      Full-stack engineer focused on scalable systems, AI workflows, and polished product experiences. I care about shipping quickly,
      owning outcomes, and building software that is both reliable and creative.
    </p>
    <div class="mt-6 flex flex-wrap gap-2 text-sm">
      <a class="rounded-lg border border-slate-700 px-3 py-2 hover:border-sky-400" href="mailto:kianranjbar7@gmail.com">kianranjbar7@gmail.com</a>
      <a class="rounded-lg border border-slate-700 px-3 py-2 hover:border-sky-400" href="https://github.com/kfr7" target="_blank" rel="noreferrer">GitHub</a>
      <a class="rounded-lg border border-slate-700 px-3 py-2 hover:border-sky-400" href="https://linkedin.com/in/kian-ranjbar-12685a20a" target="_blank" rel="noreferrer">LinkedIn</a>
      <span class="rounded-lg border border-slate-700 px-3 py-2 text-slate-300">Los Angeles, CA</span>
    </div>
  </section>

  <section class="mt-5 grid gap-4 md:grid-cols-3">
    <article class="glass md:col-span-2">
      <h2 class="text-xl font-semibold">Experience</h2>
      <div class="mt-4 space-y-3">
        {experience.map((item) => (
          <div class="rounded-xl border border-slate-700/70 bg-slate-950/60 p-4">
            <div class="flex items-center gap-3">
              {item.logo ? (
                <img src={item.logo} alt={`${item.company} logo`} class="h-9 w-9 rounded bg-white/90 object-contain p-1" loading="lazy" />
              ) : (
                <div class="grid h-9 w-9 place-items-center rounded border border-slate-700 text-xs font-semibold text-slate-400">THS</div>
              )}
              <div>
                <h3 class="text-sm font-semibold md:text-base">{item.role}</h3>
                <p class="text-xs text-slate-400 md:text-sm">{item.company} · {item.period}</p>
              </div>
            </div>
            <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-300">
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </article>

    <aside class="space-y-4">
      <article class="glass">
        <h2 class="text-xl font-semibold">Education</h2>
        <p class="mt-3 text-sm text-slate-300"><strong>University of California, Irvine</strong></p>
        <p class="text-sm text-slate-300">B.S. Computer Science</p>
        <p class="text-sm text-slate-300">Specialization: Information Management & Data Analytics</p>
        <p class="text-sm text-slate-400">GPA: 3.992 · Sep 2020 — Dec 2023</p>
      </article>

      <article class="glass">
        <h2 class="text-xl font-semibold">Core Skills</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {skills.map((skill) => <span class="skill-chip">{skill}</span>)}
        </div>
      </article>

      <article class="glass">
        <h2 class="text-xl font-semibold">Outside Engineering</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
          <li>⚽ Juggling a soccer ball at the beach</li>
          <li>🏋️ Consistent gym sessions</li>
          <li>🎬 Watching movies at home</li>
          <li>🤖 I <strong>will</strong> be buying an at-home robot assistant once they are great.</li>
        </ul>
      </article>
    </aside>
  </section>

  <footer class="py-7 text-center text-sm text-slate-400">
    Built with Astro + Tailwind. Deploy on Vercel for the easiest workflow.
  </footer>
</BaseLayout>
