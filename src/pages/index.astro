---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  'Python', 'JavaScript', 'React', 'Vue', 'Node.js', 'Express', 'SQL', 'AWS', 'GCP', 'Docker',
  'Cypress', 'OpenAI', 'Tailwind CSS', 'MongoDB', 'PostgreSQL', 'CI/CD', 'Generative AI'
];

const highlights = [
  {
    title: 'Brandboom — Full-Stack Engineer II → III',
    period: 'Jan 2024 — Present',
    logo: 'https://logo.clearbit.com/brandboom.com',
    points: [
      'Promoted to Engineer III in 15 months in a high-speed product environment.',
      'Shipped AI-powered workflows, sync systems, and data pipelines with measurable impact.',
      'Drove frontend modernization and test reliability while mentoring teammates.'
    ]
  },
  {
    title: 'Course Hero — Backend / Full-Stack Engineering Intern',
    period: 'Jun 2022 — Sep 2023',
    logo: 'https://logo.clearbit.com/coursehero.com',
    points: [
      'Built event-driven backend capabilities on AWS to improve processing speed and resilience.',
      'Delivered APIs and documentation that improved product experience and team collaboration.'
    ]
  }
];
---

<BaseLayout title="Kian Fabian Ranjbar | Portfolio" description="Creative full-stack portfolio of Kian Fabian Ranjbar">
  <section class="glass overflow-hidden p-6 md:p-8">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="panel-title">SYSTEM.ONLINE — LOS ANGELES</p>
        <h1 class="neon mt-3 text-4xl font-bold tracking-tight md:text-6xl">Kian Fabian Ranjbar</h1>
        <p class="mt-4 max-w-3xl text-slate-300">
          Full-stack engineer building scalable products with AI, data, and clean UX. I’m a shipping-focused engineer who likes hard
          problems, quick iteration, and making software feel alive.
        </p>
      </div>
      <div class="grid gap-2 text-sm">
        <a class="rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-2 hover:border-cyan-400" href="mailto:kianranjbar7@gmail.com">kianranjbar7@gmail.com</a>
        <a class="rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-2 hover:border-cyan-400" href="https://github.com/kfr7" target="_blank" rel="noreferrer">github.com/kfr7</a>
        <a class="rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-2 hover:border-cyan-400" href="https://linkedin.com/in/kian-ranjbar-12685a20a" target="_blank" rel="noreferrer">linkedin.com/in/kian-ranjbar-12685a20a</a>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap gap-2">
      {skills.map((skill) => <span class="skill-chip">{skill}</span>)}
    </div>
  </section>

  <section class="mt-4 grid gap-4 md:grid-cols-3">
    <article class="glass p-5 md:col-span-2">
      <h2 class="panel-title">MISSION LOG / EXPERIENCE</h2>
      <div class="mt-4 space-y-4">
        {highlights.map((item) => (
          <div class="rounded-xl border border-slate-700/70 bg-slate-950/60 p-4 transition hover:-translate-y-0.5 hover:border-cyan-300/70">
            <div class="flex items-center gap-3">
              <img src={item.logo} alt="company logo" class="h-9 w-9 rounded bg-white/90 object-contain p-1" loading="lazy" />
              <div>
                <h3 class="font-semibold">{item.title}</h3>
                <p class="text-sm text-slate-400">{item.period}</p>
              </div>
            </div>
            <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-300">
              {item.points.map((point) => <li>{point}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-4 rounded-xl border border-dashed border-cyan-400/30 bg-cyan-400/5 p-4 text-sm text-cyan-100">
        Also taught C++ as a UCI ICS tutor and founded my high school programming club to help classmates break into CS.
      </div>
    </article>

    <aside class="space-y-4">
      <article class="glass p-5">
        <h2 class="panel-title">EDUCATION</h2>
        <p class="mt-3 text-sm text-slate-300"><strong>University of California, Irvine</strong></p>
        <p class="text-sm text-slate-300">B.S. Computer Science</p>
        <p class="text-sm text-slate-400">Specialization in Information Management & Data Analytics</p>
        <p class="text-sm text-slate-400">GPA 3.992 · 2020–2023</p>
      </article>

      <article class="glass p-5">
        <h2 class="panel-title">HUMAN PATCH NOTES</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
          <li>Beach soccer juggling sessions keep me sane.</li>
          <li>Gym discipline translates directly to engineering consistency.</li>
          <li>Home movie nights are my favorite reset ritual.</li>
          <li>I absolutely plan to buy a home robot assistant once they’re truly useful.</li>
        </ul>
      </article>
    </aside>
  </section>

  <section class="mt-4 grid gap-4 md:grid-cols-2">
    <article class="glass p-5">
      <h2 class="panel-title">IMPACT OUTSIDE CODE</h2>
      <p class="mt-3 text-sm text-slate-300">
        Co-founder of a nonprofit charity organization running for over 10 years supporting orphanages in Tijuana, Mexico.
        Building systems matters, but so does building community.
      </p>
    </article>

    <article class="glass p-5">
      <h2 class="panel-title">SOCCER MODE (MINI CLIP)</h2>
      <p class="mt-2 text-xs text-slate-400">A little flair inspiration:</p>
      <div class="mt-3 aspect-video overflow-hidden rounded-xl border border-slate-700">
        <iframe
          class="h-full w-full"
          src="https://www.youtube.com/embed/3fQ7w4fQfwo?autoplay=1&mute=1&controls=1&rel=0"
          title="Ronaldinho highlights"
          loading="lazy"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </article>
  </section>

  <section class="mt-4 glass p-5">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="panel-title">MINI GAME — BUG HUNTER</h2>
      <p class="text-xs text-slate-400">Click the moving bug. 20 seconds. High score stays in this browser.</p>
    </div>
    <div class="mt-3 grid gap-3 md:grid-cols-[1fr_auto] md:items-center">
      <div class="relative h-44 rounded-xl border border-slate-700 bg-slate-950/70" id="arena">
        <button id="bug" class="absolute left-5 top-5 text-2xl transition hover:scale-110" aria-label="bug">🐞</button>
      </div>
      <div class="rounded-xl border border-slate-700 bg-slate-950/60 p-3 text-sm">
        <p>Time: <span id="time">20</span>s</p>
        <p>Score: <span id="score">0</span></p>
        <p>Best: <span id="best">0</span></p>
        <button id="start" class="mt-2 rounded-lg border border-cyan-400/50 px-3 py-1 text-cyan-200 hover:bg-cyan-400/10">Start</button>
      </div>
    </div>
  </section>

  <script is:inline>
    const arena = document.getElementById('arena');
    const bug = document.getElementById('bug');
    const start = document.getElementById('start');
    const timeEl = document.getElementById('time');
    const scoreEl = document.getElementById('score');
    const bestEl = document.getElementById('best');

    let timer = 20;
    let score = 0;
    let gameInterval;
    let moveInterval;
    const best = Number(localStorage.getItem('kian-bug-best') || 0);
    bestEl.textContent = String(best);

    const moveBug = () => {
      const x = Math.random() * (arena.clientWidth - 44);
      const y = Math.random() * (arena.clientHeight - 44);
      bug.style.left = `${x}px`;
      bug.style.top = `${y}px`;
    };

    bug.addEventListener('click', () => {
      if (timer <= 0) return;
      score += 1;
      scoreEl.textContent = String(score);
      moveBug();
    });

    start.addEventListener('click', () => {
      clearInterval(gameInterval);
      clearInterval(moveInterval);
      timer = 20;
      score = 0;
      timeEl.textContent = '20';
      scoreEl.textContent = '0';
      moveBug();
      moveInterval = setInterval(moveBug, 700);
      gameInterval = setInterval(() => {
        timer -= 1;
        timeEl.textContent = String(timer);
        if (timer <= 0) {
          clearInterval(gameInterval);
          clearInterval(moveInterval);
          const currentBest = Number(localStorage.getItem('kian-bug-best') || 0);
          if (score > currentBest) {
            localStorage.setItem('kian-bug-best', String(score));
            bestEl.textContent = String(score);
          }
        }
      }, 1000);
    });
  </script>
</BaseLayout>
